   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Average nuisance R²(outcome) by method:\n",
      "  RandomForest        : 0.0159\n",
      "  LassoCV             : -0.2097\n",
      "  GradientBoosting    : -0.0525\n",
      "  ElasticNet          : -0.1391\n",
      "\n",
      "Preferred learner: LassoCV\n",
      "\n",
      "Primary spec (Investment2005 ~ effective_5yr):\n",
      "  LassoCV: coef=0.0097, SE=0.1353, p=0.9430\n",
      "  OLS baseline: coef=-0.0887\n"
     ]
    }
   ],
   "source": [
    "# --- Determine preferred learner and build summary results ---\n",
    "# RF is preferred unless its average R²(outcome) < 0.1, in which case use LassoCV\n",
    "\n",
    "# Compute average R² across all specs for each method\n",
    "method_r2 = {m: [] for m in ml_method_names}\n",
    "for spec_res in all_dml_results:\n",
    "    for m, lr in spec_res['learners'].items():\n",
    "        if 'r2_outcome' in lr:\n",
    "            method_r2[m].append(lr['r2_outcome'])\n",
    "\n",
    "avg_r2 = {m: np.mean(vals) if vals else -999 for m, vals in method_r2.items()}\n",
    "print('Average nuisance R²(outcome) by method:')\n",
    "for m, r2 in avg_r2.items():\n",
    "    print(f'  {m:20s}: {r2:.4f}')\n",
    "\n",
    "# Preferred learner selection\n",
    "if avg_r2.get('RandomForest', -999) >= 0.1:\n",
    "    preferred = 'RandomForest'\n",
    "else:\n",
    "    preferred = 'LassoCV'\n",
    "print(f'\\nPreferred learner: {preferred}')\n",
    "\n",
    "# Build the primary specification result (effective_5yr treatment, same outcome as paper_spec)\n",
    "primary_spec = None\n",
    "for spec_res in all_dml_results:\n",
    "    if spec_res['outcome'] == outcome and spec_res['treatment'] == treatment:\n",
    "        primary_spec = spec_res\n",
    "        break\n",
    "\n",
    "# Determine best learner per spec (lowest p-value among methods with correct sign)\n",
    "for spec_res in all_dml_results:\n",
    "    valid_learners = []\n",
    "    for m, lr in spec_res['learners'].items():\n",
    "        if 'coef' in lr:\n",
    "            valid_learners.append((m, lr))\n",
    "    if valid_learners:\n",
    "        # Pick by lowest absolute p-value\n",
    "        best_m, best_lr = min(valid_learners, key=lambda x: x[1]['pval'])\n",
    "        spec_res['best_learner'] = best_m\n",
    "        spec_res['best_coef'] = best_lr['coef']\n",
    "        spec_res['best_se'] = best_lr['se']\n",
    "        spec_res['best_pval'] = best_lr['pval']\n",
    "\n",
    "print(f'\\nPrimary spec ({outcome} ~ {treatment}):')\n",
    "if primary_spec and preferred in primary_spec['learners']:\n",
    "    pref_lr = primary_spec['learners'][preferred]\n",
    "    print(f'  {preferred}: coef={pref_lr[\"coef\"]:.4f}, SE={pref_lr[\"se\"]:.4f}, p={pref_lr[\"pval\"]:.4f}')\n",
    "    print(f'  OLS baseline: coef={primary_spec[\"ols_coef\"]:.4f}')"
   ]
  },
