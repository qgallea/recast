   "source": [
    "# --- Forest plot: OLS vs DML across methods for effective_5yr treatment ---\n",
    "# One panel per outcome, showing OLS + 4 DML methods\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "axes = axes.flatten()\n",
    "\n",
    "method_colors = {\n",
    "    'OLS': '#888888',\n",
    "    'RandomForest': '#1f77b4',\n",
    "    'LassoCV': '#2ca02c',\n",
    "    'GradientBoosting': '#d62728',\n",
    "    'ElasticNet': '#9467bd'\n",
    "}\n",
    "method_display = {\n",
    "    'RandomForest': 'DML (Random Forest)',\n",
    "    'LassoCV': 'DML (Lasso)',\n",
    "    'GradientBoosting': 'DML (Boosting)',\n",
    "    'ElasticNet': 'DML (Elastic Net)'\n",
    "}\n",
    "\n",
    "# Reference values from Baiardi & Naghi Table 1 (effective_5yr)\n",
    "bn_ref = {\n",
    "    'Investment2005': {'Lasso': -0.178, 'Boosting': -0.199, 'Forest': -0.204, 'OLS': -0.189},\n",
    "    'FDI2005': {'Lasso': -0.162, 'Boosting': -0.169, 'Forest': -0.177, 'OLS': -0.095},\n",
    "    'nbusinessdensitycf': {'Lasso': -0.093, 'Boosting': -0.11, 'Forest': -0.104, 'OLS': -0.070},\n",
    "    'nentryrateav': {'Lasso': -0.156, 'Boosting': -0.155, 'Forest': -0.15, 'OLS': -0.133}\n",
    "}\n",
    "\n",
    "for idx, y_var in enumerate(outcomes):\n",
    "    ax = axes[idx]\n",
    "\n",
    "    # Find this spec (effective_5yr treatment)\n",
    "    spec_res = None\n",
    "    for s in all_dml_results:\n",
    "        if s['outcome'] == y_var and s['treatment'] == 'effective_5yr':\n",
    "            spec_res = s\n",
    "            break\n",
    "\n",
    "    if spec_res is None:\n",
    "        ax.set_title(panel_labels.get(y_var, y_var) + ' — no results')\n",
    "        continue\n",
    "\n",
    "    labels = []\n",
    "    coefs = []\n",
    "    ci_los = []\n",
    "    ci_his = []\n",
    "    colors = []\n",
    "\n",
    "    # OLS baseline\n",
    "    if spec_res['ols_coef'] is not None:\n",
    "        labels.append('OLS (replicated)')\n",
    "        coefs.append(spec_res['ols_coef'])\n",
    "        ci_los.append(spec_res['ols_coef'] - 1.96 * spec_res['ols_se'])\n",
    "        ci_his.append(spec_res['ols_coef'] + 1.96 * spec_res['ols_se'])\n",
    "        colors.append(method_colors['OLS'])\n",
    "\n",
    "    # DML methods\n",
    "    for m in ml_method_names:\n",
    "        if m in spec_res['learners'] and 'coef' in spec_res['learners'][m]:\n",
    "            lr = spec_res['learners'][m]\n",
    "            labels.append(method_display.get(m, m))\n",
    "            coefs.append(lr['coef'])\n",
    "            ci_los.append(lr['ci_lo'])\n",
    "            ci_his.append(lr['ci_hi'])\n",
    "            colors.append(method_colors.get(m, '#333333'))\n",
    "\n",
    "    y_pos = np.arange(len(labels))\n",
    "    xerr_lo = [c - lo for c, lo in zip(coefs, ci_los)]\n",
    "    xerr_hi = [hi - c for c, hi in zip(coefs, ci_his)]\n",
    "\n",
    "    ax.errorbar(coefs, y_pos, xerr=[xerr_lo, xerr_hi],\n",
    "                fmt='o', capsize=4, capthick=1.5, markersize=7,\n",
    "                color='black', ecolor='black', elinewidth=1.5)\n",
    "    # Color the markers\n",
    "    for i, (c, color) in enumerate(zip(coefs, colors)):\n",
    "        ax.plot(c, y_pos[i], 'o', color=color, markersize=8, zorder=5)\n",
    "\n",
    "    ax.axvline(x=0, color='grey', linestyle='--', linewidth=0.8, alpha=0.7)\n",
    "    ax.set_yticks(y_pos)\n",
    "    ax.set_yticklabels(labels, fontsize=9)\n",
    "    ax.invert_yaxis()\n",
    "    ax.set_xlabel('Coefficient estimate', fontsize=9)\n",
    "    ax.set_title(f'{panel_labels.get(y_var, y_var)} (N={spec_res[\"n_obs\"]})', fontsize=11, fontweight='bold')\n",
    "    ax.tick_params(axis='x', labelsize=8)\n",
    "\n",
    "fig.suptitle('OLS vs DML Estimates — Five-year Effective Tax Rate\\n(Djankov et al. 2010, Table 5D specifications)',\n",
    "             fontsize=13, fontweight='bold', y=1.02)\n",
    "fig.tight_layout()\n",
    "\n",
    "for ext in ['pdf', 'png']:\n",
    "    fig.savefig(str(FIGURES_DIR / f'forest_plot.{ext}'), dpi=200, bbox_inches='tight')\n",
    "plt.close(fig)\n",
    "print(f'Saved forest_plot.pdf and forest_plot.png to {FIGURES_DIR}')"
   ]
  },
