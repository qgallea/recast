   "source": [
    "# --- Write dml_results.json ---\n",
    "# Build the full output structure\n",
    "\n",
    "# Primary specification details for top-level fields\n",
    "pref_lr = primary_spec['learners'].get(preferred, {}) if primary_spec else {}\n",
    "\n",
    "# Check for any sign change in primary spec preferred learner\n",
    "any_sign_change = False\n",
    "for spec_res in all_dml_results:\n",
    "    for m, lr in spec_res['learners'].items():\n",
    "        if lr.get('sign_change', False):\n",
    "            any_sign_change = True\n",
    "\n",
    "dml_output = {\n",
    "    'model_type': model_type,\n",
    "    'n_folds': N_FOLDS,\n",
    "    'n_rep': N_REP,\n",
    "    'ml_methods': ml_method_names,\n",
    "    'preferred_learner': preferred,\n",
    "    'preferred_coef': pref_lr.get('coef'),\n",
    "    'preferred_se': pref_lr.get('se'),\n",
    "    'preferred_ci_lo': pref_lr.get('ci_lo'),\n",
    "    'preferred_ci_hi': pref_lr.get('ci_hi'),\n",
    "    'preferred_pval': pref_lr.get('pval'),\n",
    "    'sign_change': any_sign_change,\n",
    "    'nuisance_scores': {\n",
    "        'avg_r2_outcome': {m: round(avg_r2[m], 4) for m in ml_method_names},\n",
    "        'avg_r2_treatment': {\n",
    "            m: round(np.mean([\n",
    "                s['learners'][m]['r2_treatment']\n",
    "                for s in all_dml_results\n",
    "                if m in s['learners'] and 'r2_treatment' in s['learners'][m]\n",
    "            ]), 4) if any(\n",
    "                m in s['learners'] and 'r2_treatment' in s['learners'][m]\n",
    "                for s in all_dml_results\n",
    "            ) else None\n",
    "            for m in ml_method_names\n",
    "        }\n",
    "    },\n",
    "    'specifications': all_dml_results\n",
    "}\n",
    "\n",
    "DML_RESULTS.write_text(json.dumps(dml_output, indent=2))\n",
    "print(f'Wrote {DML_RESULTS}')\n",
    "print(f'  {len(all_dml_results)} specifications x {len(ml_method_names)} ML methods')\n",
    "print(f'  Preferred learner: {preferred}')\n",
    "print(f'  Primary spec coef: {pref_lr.get(\"coef\")} (SE: {pref_lr.get(\"se\")})')\n",
    "print(f'  Any sign change: {any_sign_change}')"
   ]
