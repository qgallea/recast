    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Re-fitted LassoCV with n_rep=1 for GATE/CATE: coef=-0.0707\n",
      "GATE grouping variable: other_taxes (nunique=52)\n",
      "Group sizes: {'Q1 (low)': 14, 'Q2': 13, 'Q3': 13, 'Q4 (high)': 13}\n",
      "\n",
      "GATE results:\n",
      "                    2.5 %    effect    97.5 %\n",
      "group_Q1 (low)  -0.821354 -0.161742  0.497870\n",
      "group_Q2        -0.892190  0.141491  1.175172\n",
      "group_Q3        -1.196594 -0.190342  0.815910\n",
      "group_Q4 (high) -0.439640 -0.031649  0.376342\n",
      "\n",
      "Heterogeneity detected: False\n",
      "  Q1 (low): coef=-0.1617  CI=[-0.8214, 0.4979]\n",
      "  Q2: coef=0.1415  CI=[-0.8922, 1.1752]\n",
      "  Q3: coef=-0.1903  CI=[-1.1966, 0.8159]\n",
      "  Q4 (high): coef=-0.0316  CI=[-0.4396, 0.3763]\n"
     ]
    }
   ],
   "source": [
    "# --- GATE: Group Average Treatment Effects ---\n",
    "# DoubleML gate()/cate() requires n_rep=1, so we re-fit the preferred learner\n",
    "# with n_rep=1 for the primary specification.\n",
    "\n",
    "obj_preferred_main = fitted_models.get((outcome, treatment, preferred))\n",
    "if obj_preferred_main is None:\n",
    "    print('WARNING: No fitted model for primary spec. Skipping GATE.')\n",
    "    hte_results = None\n",
    "    obj_gate = None\n",
    "else:\n",
    "    # Prepare clean data for primary spec\n",
    "    key_cols_primary = [outcome, treatment] + controls\n",
    "    df_primary = df[key_cols_primary].dropna().reset_index(drop=True)\n",
    "\n",
    "    # Re-fit with n_rep=1 for GATE/CATE compatibility\n",
    "    dml_data_gate = dml.DoubleMLData(\n",
    "        df_primary, y_col=outcome, d_cols=treatment, x_cols=controls\n",
    "    )\n",
    "    ml_l_gate = make_learner(preferred)\n",
    "    ml_m_gate = make_learner(preferred)\n",
    "    obj_gate = dml.DoubleMLPLR(\n",
    "        dml_data_gate, ml_l=ml_l_gate, ml_m=ml_m_gate,\n",
    "        n_folds=N_FOLDS, n_rep=1\n",
    "    )\n",
    "    obj_gate.fit()\n",
    "    print(f'Re-fitted {preferred} with n_rep=1 for GATE/CATE: coef={obj_gate.coef[0]:.4f}')\n",
    "\n",
    "    # Choose grouping variable - use first control if continuous\n",
    "    group_var = controls[0]  # other_taxes\n",
    "    n_unique = df_primary[group_var].nunique()\n",
    "    if n_unique < 4:\n",
    "        group_var = treatment\n",
    "    print(f'GATE grouping variable: {group_var} (nunique={df_primary[group_var].nunique()})')\n",
    "\n",
    "    # Create quartile groups\n",
    "    try:\n",
    "        quartiles = pd.qcut(df_primary[group_var], q=4, labels=['Q1 (low)', 'Q2', 'Q3', 'Q4 (high)'])\n",
    "    except ValueError:\n",
    "        quartiles = pd.qcut(df_primary[group_var].rank(method='first'), q=4,\n",
    "                           labels=['Q1 (low)', 'Q2', 'Q3', 'Q4 (high)'])\n",
    "\n",
    "    # DoubleML gate() requires bool dtype (bug in v0.11.2 type check)\n",
    "    groups_df = pd.get_dummies(quartiles, prefix='group', dtype=bool)\n",
    "    print(f'Group sizes: {quartiles.value_counts().sort_index().to_dict()}')\n",
    "\n",
    "    # Fit GATE\n",
    "    gate = obj_gate.gate(groups=groups_df)\n",
    "    gate_ci = gate.confint(level=0.95, joint=True)\n",
    "    print('\\nGATE results:')\n",
    "    print(gate_ci)\n",
    "\n",
    "    # Extract GATE results\n",
    "    group_labels = ['Q1 (low)', 'Q2', 'Q3', 'Q4 (high)']\n",
    "    gate_groups = []\n",
    "    for i, label in enumerate(group_labels):\n",
    "        row = gate_ci.iloc[i]\n",
    "        if len(row) >= 3:\n",
    "            gate_groups.append({\n",
    "                'label': label,\n",
    "                'coef': round(float(row.iloc[1]), 4),\n",
    "                'ci_lo': round(float(row.iloc[0]), 4),\n",
    "                'ci_hi': round(float(row.iloc[2]), 4)\n",
    "            })\n",
    "        else:\n",
    "            gate_groups.append({\n",
    "                'label': label,\n",
    "                'coef': round(float(gate.coef[i]), 4),\n",
    "                'ci_lo': round(float(row.iloc[0]), 4),\n",
    "                'ci_hi': round(float(row.iloc[-1]), 4)\n",
    "            })\n",
    "\n",
    "    # Detect heterogeneity: check if any two CIs do not overlap\n",
    "    heterogeneity_detected = False\n",
    "    for i in range(len(gate_groups)):\n",
    "        for j in range(i + 1, len(gate_groups)):\n",
    "            ci_i = (gate_groups[i]['ci_lo'], gate_groups[i]['ci_hi'])\n",
    "            ci_j = (gate_groups[j]['ci_lo'], gate_groups[j]['ci_hi'])\n",
    "            if ci_i[0] > ci_j[1] or ci_j[0] > ci_i[1]:\n",
    "                heterogeneity_detected = True\n",
    "                break\n",
    "        if heterogeneity_detected:\n",
    "            break\n",
    "\n",
    "    hte_results = {\n",
    "        'method': 'GATE',\n",
    "        'grouping_variable': group_var,\n",
    "        'n_groups': 4,\n",
    "        'groups': gate_groups,\n",
    "        'heterogeneity_detected': heterogeneity_detected,\n",
    "        'cate_summary': None  # filled in next cell\n",
    "    }\n",
    "\n",
    "    print(f'\\nHeterogeneity detected: {heterogeneity_detected}')\n",
    "    for g in gate_groups:\n",
    "        print(f'  {g[\"label\"]}: coef={g[\"coef\"]:.4f}  CI=[{g[\"ci_lo\"]:.4f}, {g[\"ci_hi\"]:.4f}]')"
   ]
  },
