   ],
   "source": [
    "# --- CATE: Conditional Average Treatment Effects (PLR only) ---\n",
    "# Use the n_rep=1 model (obj_gate) for CATE estimation\n",
    "\n",
    "if obj_gate is not None and model_type in ('PLR', 'PLIV'):\n",
    "    try:\n",
    "        import patsy\n",
    "\n",
    "        # Build B-spline basis with df=5 (or less for small samples)\n",
    "        n_primary = len(df_primary)\n",
    "        spline_df = min(5, max(3, n_primary // 10))\n",
    "\n",
    "        basis = patsy.dmatrix(\n",
    "            f'bs({group_var}, df={spline_df}) - 1',\n",
    "            df_primary,\n",
    "            return_type='dataframe'\n",
    "        )\n",
    "        print(f'B-spline basis: {basis.shape[1]} columns (df={spline_df})')\n",
    "\n",
    "        cate = obj_gate.cate(basis=basis)\n",
    "        cate_ci = cate.confint(level=0.95, joint=True)\n",
    "\n",
    "        # Extract CATE coefficients\n",
    "        try:\n",
    "            cate_coefs = cate.coef\n",
    "            cate_summary = {\n",
    "                'mean': round(float(np.mean(cate_coefs)), 4),\n",
    "                'sd': round(float(np.std(cate_coefs)), 4),\n",
    "                'min': round(float(np.min(cate_coefs)), 4),\n",
    "                'max': round(float(np.max(cate_coefs)), 4)\n",
    "            }\n",
    "        except Exception:\n",
    "            ci_midpoints = (cate_ci.iloc[:, 0].values + cate_ci.iloc[:, -1].values) / 2\n",
    "            cate_summary = {\n",
    "                'mean': round(float(np.mean(ci_midpoints)), 4),\n",
    "                'sd': round(float(np.std(ci_midpoints)), 4),\n",
    "                'min': round(float(np.min(ci_midpoints)), 4),\n",
    "                'max': round(float(np.max(ci_midpoints)), 4)\n",
    "            }\n",
    "\n",
    "        print(f'CATE summary: {cate_summary}')\n",
    "        print('\\nCATE confidence intervals:')\n",
    "        print(cate_ci)\n",
    "\n",
    "        # Update hte_results with CATE summary\n",
    "        if hte_results is not None:\n",
    "            hte_results['cate_summary'] = cate_summary\n",
    "\n",
    "    except ImportError:\n",
    "        print('patsy not installed — skipping CATE analysis')\n",
    "    except Exception as e:\n",
    "        print(f'CATE estimation failed: {e}')\n",
    "        import traceback\n",
    "        traceback.print_exc()\n",
    "else:\n",
    "    if obj_gate is None:\n",
    "        print('Skipping CATE (no fitted model)')\n",
    "    else:\n",
    "        print('Skipping CATE (model type is IRM)')\n",
    "\n",
    "# Write hte_results.json\n",
    "HTE_RESULTS = RESULTS_DIR / 'hte_results.json'\n",
    "if hte_results is not None:\n",
    "    HTE_RESULTS.write_text(json.dumps(hte_results, indent=2))\n",
    "    print(f'\\nWrote {HTE_RESULTS}')\n",
    "else:\n",
    "    print('No HTE results to write.')"
   ]
  },
