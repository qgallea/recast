   ],
   "source": [
    "# --- Run DML for all 12 specifications (4 outcomes x 3 treatments) x 4 ML methods ---\n",
    "all_dml_results = []  # list of per-spec result dicts\n",
    "fitted_models = {}     # store fitted model objects keyed by (outcome, treatment, method)\n",
    "\n",
    "for y_var in outcomes:\n",
    "    for d_var in treatments:\n",
    "        # Listwise deletion for this specification\n",
    "        key_cols = [y_var, d_var] + controls\n",
    "        df_spec = df[key_cols].dropna().reset_index(drop=True)\n",
    "        n_obs = len(df_spec)\n",
    "\n",
    "        # Skip if too few observations for cross-fitting\n",
    "        if n_obs < N_FOLDS * 2:\n",
    "            print(f'  SKIP {y_var} ~ {d_var}: N={n_obs} too small for {N_FOLDS}-fold CV')\n",
    "            continue\n",
    "\n",
    "        # Build DoubleML data object\n",
    "        dml_data = dml.DoubleMLData(\n",
    "            df_spec, y_col=y_var, d_cols=d_var, x_cols=controls\n",
    "        )\n",
    "\n",
    "        # Get OLS baseline for comparison\n",
    "        ols = get_ols_result(y_var, d_var)\n",
    "        ols_coef = ols['replicated_coef'] if ols else None\n",
    "\n",
    "        spec_results = {\n",
    "            'outcome': y_var,\n",
    "            'outcome_label': outcome_labels.get(y_var, y_var),\n",
    "            'treatment': d_var,\n",
    "            'treatment_label': treatment_labels.get(d_var, d_var),\n",
    "            'n_obs': n_obs,\n",
    "            'ols_coef': float(ols_coef) if ols_coef is not None else None,\n",
    "            'ols_se': float(ols['replicated_se']) if ols else None,\n",
    "            'learners': {}\n",
    "        }\n",
    "\n",
    "        print(f'\\n=== {panel_labels.get(y_var, y_var)} ~ {d_var} (N={n_obs}) ===')\n",
    "\n",
    "        for method_name in ml_method_names:\n",
    "            try:\n",
    "                ml_l = make_learner(method_name)\n",
    "                ml_m = make_learner(method_name)\n",
    "\n",
    "                obj = dml.DoubleMLPLR(\n",
    "                    dml_data, ml_l=ml_l, ml_m=ml_m,\n",
    "                    n_folds=N_FOLDS, n_rep=N_REP\n",
    "                )\n",
    "                obj.fit()\n",
    "\n",
    "                coef = float(obj.coef[0])\n",
    "                se = float(obj.se[0])\n",
    "                ci = obj.confint(level=0.95)\n",
    "                ci_lo = float(ci.iloc[0, 0])\n",
    "                ci_hi = float(ci.iloc[0, 1])\n",
    "                pval = float(obj.pval[0])\n",
    "\n",
    "                # Nuisance R²\n",
    "                r2_y, r2_d = extract_nuisance_r2(obj, df_spec[y_var].values, df_spec[d_var].values)\n",
    "\n",
    "                # Sign change detection\n",
    "                sign_change = False\n",
    "                if ols_coef is not None and ols_coef != 0:\n",
    "                    sign_change = bool(np.sign(coef) != np.sign(ols_coef))\n",
    "\n",
    "                learner_result = {\n",
    "                    'coef': round(coef, 6),\n",
    "                    'se': round(se, 6),\n",
    "                    'ci_lo': round(ci_lo, 6),\n",
    "                    'ci_hi': round(ci_hi, 6),\n",
    "                    'pval': round(pval, 6),\n",
    "                    'r2_outcome': round(r2_y, 4),\n",
    "                    'r2_treatment': round(r2_d, 4),\n",
    "                    'sign_change': sign_change\n",
    "                }\n",
    "                spec_results['learners'][method_name] = learner_result\n",
    "                fitted_models[(y_var, d_var, method_name)] = obj\n",
    "\n",
    "                sig_marker = '*' if pval < 0.05 else ('†' if pval < 0.10 else '')\n",
    "                print(f'  {method_name:20s}: coef={coef:+.4f} (SE={se:.4f}) p={pval:.3f}{sig_marker}  R²(y)={r2_y:.3f} R²(d)={r2_d:.3f}')\n",
    "\n",
    "            except Exception as e:\n",
    "                print(f'  {method_name:20s}: FAILED — {e}')\n",
    "                spec_results['learners'][method_name] = {'error': str(e)}\n",
    "\n",
    "        all_dml_results.append(spec_results)\n",
    "\n",
    "print(f'\\n\\nCompleted {len(all_dml_results)} DML specifications.')"
   ]
  },
