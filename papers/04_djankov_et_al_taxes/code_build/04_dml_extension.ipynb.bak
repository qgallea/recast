   "source": [
    "# --- GATE plot + LaTeX table ---\n",
    "\n",
    "if hte_results is not None and hte_results.get('groups'):\n",
    "    groups = hte_results['groups']\n",
    "\n",
    "    # --- GATE Plot ---\n",
    "    fig, ax = plt.subplots(figsize=(8, 4))\n",
    "\n",
    "    labels = [g['label'] for g in groups]\n",
    "    coefs = [g['coef'] for g in groups]\n",
    "    ci_los = [g['ci_lo'] for g in groups]\n",
    "    ci_his = [g['ci_hi'] for g in groups]\n",
    "\n",
    "    y_pos = np.arange(len(labels))\n",
    "    xerr_lo = [c - lo for c, lo in zip(coefs, ci_los)]\n",
    "    xerr_hi = [hi - c for c, hi in zip(coefs, ci_his)]\n",
    "\n",
    "    ax.errorbar(coefs, y_pos, xerr=[xerr_lo, xerr_hi],\n",
    "                fmt='o', capsize=5, capthick=1.5, markersize=8,\n",
    "                color='#1f77b4', ecolor='#1f77b4', elinewidth=1.5)\n",
    "    ax.axvline(x=0, color='grey', linestyle='--', linewidth=0.8, alpha=0.7)\n",
    "    ax.set_yticks(y_pos)\n",
    "    ax.set_yticklabels(labels, fontsize=10)\n",
    "    ax.invert_yaxis()\n",
    "    ax.set_xlabel('GATE Coefficient (jointly valid 95% CI)', fontsize=10)\n",
    "    ax.set_title(f'Group Average Treatment Effects\\n(grouped by {group_var})', fontsize=12, fontweight='bold')\n",
    "\n",
    "    fig.tight_layout()\n",
    "    for ext in ['pdf', 'png']:\n",
    "        fig.savefig(str(FIGURES_DIR / f'gate_plot.{ext}'), dpi=200, bbox_inches='tight')\n",
    "    plt.close(fig)\n",
    "    print(f'Saved gate_plot.pdf and gate_plot.png to {FIGURES_DIR}')\n",
    "\n",
    "    # --- GATE LaTeX table ---\n",
    "    gate_lines = []\n",
    "    gate_lines.append(r'\\begin{table}[h]')\n",
    "    gate_lines.append(r'\\centering')\n",
    "    gate_lines.append(r'\\caption{Group Average Treatment Effects (GATE)}')\n",
    "    gate_lines.append(r'\\label{tab:gate}')\n",
    "    gate_lines.append(r'\\begin{tabular}{lccc}')\n",
    "    gate_lines.append(r'\\toprule')\n",
    "    gate_lines.append(r'Group & Coef. & 95\\% CI (joint) \\\\')\n",
    "    gate_lines.append(r'\\midrule')\n",
    "    for g in groups:\n",
    "        gate_lines.append(f'{g[\"label\"]} & {g[\"coef\"]:.3f} & [{g[\"ci_lo\"]:.3f}, {g[\"ci_hi\"]:.3f}] \\\\\\\\')\n",
    "    gate_lines.append(r'\\bottomrule')\n",
    "    gate_lines.append(r'\\end{tabular}')\n",
    "    gate_lines.append(r'\\begin{minipage}{0.8\\textwidth}')\n",
    "    gate_lines.append(r'\\footnotesize')\n",
    "    gate_lines.append(r'\\textit{Notes:} Groups based on quartiles of ' + group_var.replace('_', r'\\_') + '.')\n",
    "    gate_lines.append(r' CIs are jointly valid via Gaussian multiplier bootstrap.')\n",
    "    het_str = 'Yes' if hte_results['heterogeneity_detected'] else 'No'\n",
    "    gate_lines.append(r' Heterogeneity detected: ' + het_str + '.')\n",
    "    gate_lines.append(r'\\end{minipage}')\n",
    "    gate_lines.append(r'\\end{table}')\n",
    "\n",
    "    gate_tex = '\\n'.join(gate_lines)\n",
    "    (TABLES_DIR / 'table_gate.tex').write_text(gate_tex)\n",
