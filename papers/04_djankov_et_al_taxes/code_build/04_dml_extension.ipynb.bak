   ],
   "source": [
    "# --- LaTeX comparison table: OLS vs DML (4 methods) for effective_5yr ---\n",
    "# One panel per outcome (like Baiardi & Naghi Table 1)\n",
    "\n",
    "def fmt_coef(val, pval=None):\n",
    "    \"\"\"Format coefficient with significance stars.\"\"\"\n",
    "    if val is None:\n",
    "        return '---'\n",
    "    stars = ''\n",
    "    if pval is not None:\n",
    "        if pval < 0.01:\n",
    "            stars = '***'\n",
    "        elif pval < 0.05:\n",
    "            stars = '**'\n",
    "        elif pval < 0.10:\n",
    "            stars = '*'\n",
    "    return f'{val:.3f}{stars}'\n",
    "\n",
    "def fmt_se(val):\n",
    "    if val is None:\n",
    "        return ''\n",
    "    return f'({val:.3f})'\n",
    "\n",
    "def fmt_ci(lo, hi):\n",
    "    if lo is None or hi is None:\n",
    "        return ''\n",
    "    return f'[{lo:.3f}, {hi:.3f}]'\n",
    "\n",
    "lines = []\n",
    "lines.append(r'\\begin{table}[htbp]')\n",
    "lines.append(r'\\centering')\n",
    "lines.append(r'\\caption{OLS vs.\\ DML Estimates --- Five-year Effective Tax Rate (Table 5D Specifications)}')\n",
    "lines.append(r'\\label{tab:dml_comparison}')\n",
    "lines.append(r'\\small')\n",
    "lines.append(r'\\begin{tabular}{lcccccc}')\n",
    "lines.append(r'\\toprule')\n",
    "lines.append(r' & OLS & DML (Lasso) & DML (Boosting) & DML (Forest) & DML (Elastic Net) & $N$ \\\\')\n",
    "lines.append(r'\\midrule')\n",
    "\n",
    "for y_var in outcomes:\n",
    "    spec_res = None\n",
    "    for s in all_dml_results:\n",
    "        if s['outcome'] == y_var and s['treatment'] == 'effective_5yr':\n",
    "            spec_res = s\n",
    "            break\n",
    "    if spec_res is None:\n",
    "        continue\n",
    "\n",
    "    panel = panel_labels.get(y_var, y_var)\n",
    "    lines.append(r'\\multicolumn{7}{l}{\\textit{' + panel + r'}} \\\\')\n",
    "\n",
    "    # Coefficient row\n",
    "    ols_p = None\n",
    "    ols_r = get_ols_result(y_var, 'effective_5yr')\n",
    "    if ols_r:\n",
    "        ols_p = ols_r.get('p_value')\n",
    "    ols_c = fmt_coef(spec_res['ols_coef'], ols_p)\n",
    "\n",
    "    dml_cols = []\n",
    "    for m in ['LassoCV', 'GradientBoosting', 'RandomForest', 'ElasticNet']:\n",
    "        lr = spec_res['learners'].get(m, {})\n",
    "        dml_cols.append(fmt_coef(lr.get('coef'), lr.get('pval')))\n",
    "\n",
    "    lines.append(f'  Coef. & {ols_c} & {\" & \".join(dml_cols)} & {spec_res[\"n_obs\"]} \\\\\\\\')\n",
    "\n",
    "    # SE row\n",
    "    ols_se = fmt_se(spec_res['ols_se'])\n",
    "    se_cols = []\n",
    "    for m in ['LassoCV', 'GradientBoosting', 'RandomForest', 'ElasticNet']:\n",
    "        lr = spec_res['learners'].get(m, {})\n",
    "        se_cols.append(fmt_se(lr.get('se')))\n",
    "    lines.append(f'  SE & {ols_se} & {\" & \".join(se_cols)} & \\\\\\\\')\n",
    "\n",
    "    # CI row\n",
    "    if ols_r:\n",
    "        ols_ci = fmt_ci(ols_r.get('ci_lo'), ols_r.get('ci_hi'))\n",
    "    else:\n",
    "        ols_ci = ''\n",
    "    ci_cols = []\n",
    "    for m in ['LassoCV', 'GradientBoosting', 'RandomForest', 'ElasticNet']:\n",
    "        lr = spec_res['learners'].get(m, {})\n",
    "        ci_cols.append(fmt_ci(lr.get('ci_lo'), lr.get('ci_hi')))\n",
    "    lines.append(f'  95\\\\% CI & {ols_ci} & {\" & \".join(ci_cols)} & \\\\\\\\')\n",
    "\n",
    "    lines.append(r'\\addlinespace')\n",
    "\n",
    "lines.append(r'\\bottomrule')\n",
    "lines.append(r'\\end{tabular}')\n",
    "lines.append(r'\\begin{minipage}{\\textwidth}')\n",
    "lines.append(r'\\footnotesize')\n",
    "lines.append(r'\\textit{Notes:} DML estimates use DoubleMLPLR with ' + str(N_FOLDS) + r'-fold cross-fitting and ' + str(N_REP) + r' repetitions.')\n",
    "lines.append(r' Significance: $^{***}p<0.01$, $^{**}p<0.05$, $^{*}p<0.10$.')\n",
    "lines.append(r' Controls: all 12 variables from Table 5D specification.')\n",
    "lines.append(r'\\end{minipage}')\n",
    "lines.append(r'\\end{table}')\n",
    "\n",
    "table_tex = '\\n'.join(lines)\n",
    "(TABLES_DIR / 'table_dml.tex').write_text(table_tex)\n",
    "print(f'Wrote {TABLES_DIR / \"table_dml.tex\"}')\n",
    "print()\n",
    "print(table_tex)"
   ]
