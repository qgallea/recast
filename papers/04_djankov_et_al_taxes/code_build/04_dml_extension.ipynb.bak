   "source": [
    "from paths import *\n",
    "import json\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib\n",
    "matplotlib.use('Agg')\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "import doubleml as dml\n",
    "from sklearn.ensemble import RandomForestRegressor, GradientBoostingRegressor\n",
    "from sklearn.linear_model import LassoCV, ElasticNetCV\n",
    "from sklearn.metrics import r2_score\n",
    "\n",
    "df   = pd.read_parquet(str(DATASET_PATH))\n",
    "spec = json.loads(PAPER_SPEC.read_text())\n",
    "rep  = json.loads(REPLICATION_RESULTS.read_text())\n",
    "\n",
    "# Primary specification variables\n",
    "outcome   = spec['identification']['outcome_variable']\n",
    "treatment = spec['identification']['treatment_variable']\n",
    "instrument = spec['identification'].get('instrument')\n",
    "controls  = spec['identification']['controls']\n",
    "id_type   = spec['identification']['type']\n",
    "model_type = spec['dml']['model_type']  # PLR\n",
    "\n",
    "# All outcomes and treatments for full 4x3 grid\n",
    "outcomes = [o['variable'] for o in spec['identification']['additional_outcomes']]\n",
    "outcome_labels = {o['variable']: o['label'] for o in spec['identification']['additional_outcomes']}\n",
    "treatments = [t['variable'] for t in spec['identification']['additional_treatments']]\n",
    "treatment_labels = {t['variable']: t['label'] for t in spec['identification']['additional_treatments']}\n",
    "\n",
    "# ML methods from config\n",
    "ml_method_names = ['RandomForest', 'LassoCV', 'GradientBoosting', 'ElasticNet']\n",
    "\n",
    "# DML settings\n",
    "N_FOLDS = 5\n",
    "N_REP = 3\n",
    "\n",
    "print(f'DML model: {model_type}')\n",
    "print(f'Outcomes ({len(outcomes)}): {outcomes}')\n",
    "print(f'Treatments ({len(treatments)}): {treatments}')\n",
    "print(f'Controls ({len(controls)}): {controls}')\n",
    "print(f'ML methods: {ml_method_names}')\n",
    "print(f'Cross-fitting: {N_FOLDS} folds, {N_REP} repetitions')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "e9c02c96",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-30T12:46:04.010908Z",
     "iopub.status.busy": "2026-03-30T12:46:04.010673Z",
     "iopub.status.idle": "2026-03-30T12:46:04.015298Z",
     "shell.execute_reply": "2026-03-30T12:46:04.014752Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Helpers defined. Ready to run DML specifications.\n"
     ]
    }
   ],
   "source": [
    "# --- Helper: create ML learner instances ---\n",
    "# Conservative settings for small samples (N=42-53)\n",
    "def make_learner(method_name):\n",
    "    \"\"\"Return a fresh sklearn regressor for the given method name.\"\"\"\n",
    "    if method_name == 'RandomForest':\n",
    "        return RandomForestRegressor(\n",
    "            n_estimators=500, max_depth=5, min_samples_leaf=5,\n",
    "            random_state=42, n_jobs=-1\n",
    "        )\n",
    "    elif method_name == 'LassoCV':\n",
    "        return LassoCV(cv=5, random_state=42, max_iter=10000)\n",
    "    elif method_name == 'GradientBoosting':\n",
    "        return GradientBoostingRegressor(\n",
    "            n_estimators=200, max_depth=3, learning_rate=0.05,\n",
    "            min_samples_leaf=5, random_state=42\n",
    "        )\n",
    "    elif method_name == 'ElasticNet':\n",
    "        return ElasticNetCV(cv=5, l1_ratio=[0.1, 0.5, 0.7, 0.9, 0.95, 0.99],\n",
    "                            random_state=42, max_iter=10000)\n",
    "    else:\n",
    "        raise ValueError(f'Unknown method: {method_name}')\n",
    "\n",
    "# --- Helper: extract nuisance R² from a fitted DoubleML object ---\n",
    "def extract_nuisance_r2(obj, y_true, d_true):\n",
    "    \"\"\"Extract out-of-sample R² for outcome and treatment nuisance models (rep 0).\"\"\"\n",
    "    preds_y = obj.predictions['ml_l'][:, 0, 0]\n",
    "    preds_d = obj.predictions['ml_m'][:, 0, 0]\n",
    "    r2_y = float(r2_score(y_true, preds_y))\n",
    "    r2_d = float(r2_score(d_true, preds_d))\n",
    "    return r2_y, r2_d\n",
    "\n",
    "# --- Helper: lookup OLS replication result for a given outcome x treatment ---\n",
    "def get_ols_result(outcome_var, treatment_var):\n",
    "    \"\"\"Return the OLS replication dict for this spec, or None.\"\"\"\n",
    "    for s in rep['specs']:\n",
    "        if s['outcome'] == outcome_var and s['treatment'] == treatment_var:\n",
    "            return s\n",
    "    return None\n",
    "\n",
    "# Panel labels for display\n",
    "panel_labels = {\n",
    "    'Investment2005': 'Panel A: Investment',\n",
    "    'FDI2005': 'Panel B: FDI',\n",
    "    'nbusinessdensitycf': 'Panel C: Business density',\n",
    "    'nentryrateav': 'Panel D: Entry rate'\n",
    "}\n",
    "\n",
    "print('Helpers defined. Ready to run DML specifications.')"
   ]
  },
